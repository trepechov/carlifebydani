# Theme build output
/theme/dist

# Theme dependencies
/theme/node_modules

# Plugin dependencies (future)
/plugins/*/node_modules
/plugins/*/vendor

# Zip archives
*.zip

# Editor configuration
/.vscode
/.idea
/.history

# OS-generated files
.DS_Store
Thumbs.db

# Credentials (never commit)
/.credentials

# Local Claude Code settings (personal MCP servers, permissions)
/.claude/settings.local.json
# Test output (generated files, never commit)
/plugins/*/tests/output/
